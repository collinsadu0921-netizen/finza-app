# =============================================================================
# Finza — example environment variables
# =============================================================================
# Copy this file to .env.local and fill in real values. Never commit .env.local.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (required for app and API)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Use the "anon" / "public" key here (Dashboard → Project Settings → API). Never use the service_role key in the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key (server-side only; never expose via NEXT_PUBLIC_*; required for some API routes and cron)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Resend — transactional email (invoices, estimates, orders, receipts, credit notes)
# -----------------------------------------------------------------------------
# Get an API key at https://resend.com — required for sending email.
# If unset, send flows no-op in dev (log only) and fail in production.
RESEND_API_KEY=re_xxxxxxxxxxxx
# From address — must use a domain verified in your Resend account.
# The display name ("Finza") is replaced per-send with "Business Name via Finza".
# Example: RESEND_FROM=Finza <noreply@mail.finza.app>
RESEND_FROM=Finza <noreply@mail.finza.app>

# -----------------------------------------------------------------------------
# App URL (strongly recommended in production)
# -----------------------------------------------------------------------------
# Canonical site URL (https://your-domain.com). Used for email/WhatsApp links.
# Paystack subscription card checkout uses this for callback_url when set; if
# unset, the API falls back to the request Host (live site) or VERCEL_URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Signup gate — website-controlled service signup (optional)
# -----------------------------------------------------------------------------
# When NEXT_PUBLIC_SIGNUP_REQUIRE_SERVICE_PLAN_CONTEXT=true, /signup only loads
# for business-owner service signup if the URL includes valid marketing context:
#   workspace=service&plan=<tier>   (tier: starter|essentials|professional|… aliases — see tryParseServiceSubscriptionTier)
# Optional: trial=1, cycle=… (ignored by the gate; reserved for future use).
# Accounting firms bypass the gate with: flow=accounting_firm
# Everyone else is redirected to NEXT_PUBLIC_MARKETING_PRICING_URL (full URL).
# Leave the flag unset or not "true" for local dev and legacy direct /signup access.
# NEXT_PUBLIC_SIGNUP_REQUIRE_SERVICE_PLAN_CONTEXT=true
# NEXT_PUBLIC_MARKETING_PRICING_URL=https://finza.africa/pricing

# -----------------------------------------------------------------------------
# Retail POS — shared tablet / kiosk (optional)
# -----------------------------------------------------------------------------
# Email/password sessions use cookies and stay signed in after closing the tab.
# Cashiers who only use PIN rely on sessionStorage (clears when the tab closes).
# On shared POS hardware, set a positive number to auto sign out after idle on
# /pos and /retail/pos (mouse, keyboard, scroll, or touch resets the timer).
# Example: NEXT_PUBLIC_RETAIL_POS_IDLE_LOGOUT_MINUTES=15
# NEXT_PUBLIC_RETAIL_POS_IDLE_LOGOUT_MINUTES=

# -----------------------------------------------------------------------------
# E2E — Playwright service workspace (optional)
# -----------------------------------------------------------------------------
# Create a Supabase user that lands in the service workspace (industry = service).
# If the user sees /select-workspace, pick the service card or set E2E_SERVICE_BUSINESS_NAME.
# E2E_SERVICE_EMAIL=
# E2E_SERVICE_PASSWORD=
# E2E_SERVICE_BUSINESS_NAME=
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# Receipt OCR (POST /api/receipt-ocr) — free local Tesseract via tesseract.js
# -----------------------------------------------------------------------------
# Omit or set false: run real OCR (first request may download ~eng traineddata~).
# Set true: use stub text only (fast dev, no WASM).
# RECEIPT_OCR_USE_STUB=true
#
# Before OCR, large images are downscaled (sharp) to speed Tesseract / avoid timeouts.
# RECEIPT_OCR_MAX_EDGE_PX=1600
# RECEIPT_OCR_SKIP_DOWNSCALE=true

# -----------------------------------------------------------------------------
# Paystack — card & mobile money (test: sk_test_… / pk_test_… from Dashboard → Settings → API Keys)
# -----------------------------------------------------------------------------
# Server: charge, verify, submit-otp, and webhook HMAC (must match the key pair you use in the dashboard).
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Client: only needed where the UI exposes Paystack (e.g. public pay page). Never put the secret key in NEXT_PUBLIC_*.
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Webhooks (charge.success, etc.): point Paystack to your deployed URL, e.g.
#   https://your-domain.com/api/payments/webhooks/mobile-money
# Local dev: use ngrok/cloudflared and register that URL in Paystack → Settings → Webhooks (test mode).

# -----------------------------------------------------------------------------
# Tenant payment provider config (server-only) — encrypts business_payment_providers.secret_config_encrypted
# -----------------------------------------------------------------------------
# Required for saving integrated provider secrets (MTN/Paystack tenant keys, etc.).
# Must be exactly 32 bytes of key material (after trim), in one of these forms:
#   - 64 hex characters (recommended)
#   - Base64 or base64url encoding of exactly 32 raw bytes
# Do not use passphrases. Do not reuse third-party API keys as this key.
#
# Generate locally:
#   openssl rand -hex 32
#   # or (Windows / no OpenSSL):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Copy the value into .env.local and set the same variable on Vercel (Production
# + Preview) if you deploy. Changing the key later invalidates existing ciphertext.
# TENANT_PAYMENT_CONFIG_ENCRYPTION_KEY=paste_output_of_openssl_or_node_command_here

# -----------------------------------------------------------------------------
# Optional feature flags / integrations
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SERVICE_ANALYTICS_V2=true
# FORENSIC_ALERT_EMAIL=alerts@yourdomain.com
#
# Onboarding AI assistant (optional)
# Uses AI SDK + OpenAI provider in app/api/onboarding/assistant/route.ts
# OPENAI_API_KEY=sk-...
# ONBOARDING_AI_MODEL=gpt-5-mini
#
# Local/open-source assistant via Ollama-compatible OpenAI API
# Defaults in app/api/ai/route.ts:
#   AI_BASE_URL=http://localhost:11434/v1
#   AI_MODEL=gemma3:12b
#   AI_API_KEY=ollama
# AI_BASE_URL=http://localhost:11434/v1
# AI_MODEL=gemma3:12b
# AI_API_KEY=ollama

RECEIPT_OCR_USE_STUB=true
