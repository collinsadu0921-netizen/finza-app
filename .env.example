# =============================================================================
# Finza — example environment variables
# =============================================================================
# Copy this file to .env.local and fill in real values. Never commit .env.local.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (required for app and API)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Use the "anon" / "public" key here (Dashboard → Project Settings → API). Never use the service_role key in the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key (server-side only; never expose via NEXT_PUBLIC_*; required for some API routes and cron)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Resend — transactional email (invoices, estimates, orders, receipts, credit notes)
# -----------------------------------------------------------------------------
# Get an API key at https://resend.com — required for sending email.
# If unset, send flows no-op in dev (log only) and fail in production.
RESEND_API_KEY=re_xxxxxxxxxxxx
# From address — must use a domain verified in your Resend account.
# The display name ("Finza") is replaced per-send with "Business Name via Finza".
# Example: RESEND_FROM=Finza <noreply@mail.finza.app>
RESEND_FROM=Finza <noreply@mail.finza.app>

# -----------------------------------------------------------------------------
# App URL (optional; used for public links in emails and WhatsApp)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# E2E — Playwright service workspace (optional)
# -----------------------------------------------------------------------------
# Create a Supabase user that lands in the service workspace (industry = service).
# If the user sees /select-workspace, pick the service card or set E2E_SERVICE_BUSINESS_NAME.
# E2E_SERVICE_EMAIL=
# E2E_SERVICE_PASSWORD=
# E2E_SERVICE_BUSINESS_NAME=
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# Receipt OCR (POST /api/receipt-ocr) — free local Tesseract via tesseract.js
# -----------------------------------------------------------------------------
# Omit or set false: run real OCR (first request may download ~eng traineddata~).
# Set true: use stub text only (fast dev, no WASM).
# RECEIPT_OCR_USE_STUB=true
#
# Before OCR, large images are downscaled (sharp) to speed Tesseract / avoid timeouts.
# RECEIPT_OCR_MAX_EDGE_PX=1600
# RECEIPT_OCR_SKIP_DOWNSCALE=true

# -----------------------------------------------------------------------------
# Optional feature flags / integrations
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SERVICE_ANALYTICS_V2=true
# FORENSIC_ALERT_EMAIL=alerts@yourdomain.com

RECEIPT_OCR_USE_STUB=true
