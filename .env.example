# =============================================================================
# Finza — example environment variables
# =============================================================================
# Copy this file to .env.local and fill in real values. Never commit .env.local.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (required for app and API)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Use the "anon" / "public" key here (Dashboard → Project Settings → API). Never use the service_role key in the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key (server-side only; never expose via NEXT_PUBLIC_*; required for some API routes and cron)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Resend — transactional email (invoices, estimates, orders, receipts, credit notes)
# -----------------------------------------------------------------------------
# Get an API key at https://resend.com — required for sending email.
# If unset, send flows no-op in dev (log only) and fail in production.
RESEND_API_KEY=re_xxxxxxxxxxxx
# From address — must use a domain verified in your Resend account.
# The display name ("Finza") is replaced per-send with "Business Name via Finza".
# Example: RESEND_FROM=Finza <noreply@mail.finza.app>
RESEND_FROM=Finza <noreply@mail.finza.app>
# Webhook signing secret from Resend dashboard (starts with whsec_). Required for POST /api/webhooks/resend
# and POST /api/webhooks/resend-inbound (same Svix signing secret; subscribe to email.received for inbound).
# RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Inbound email (Stage 4A/4B) — receiving domain for business routing addresses
# -----------------------------------------------------------------------------
# MX hostname you configure in DNS / Resend inbound (no @). Used when generating
# addresses like fd…hex…@inbound.yourdomain.com for POST /api/business/inbound-email.
# FINZA_INBOUND_EMAIL_DOMAIN=inbound.yourdomain.com

# -----------------------------------------------------------------------------
# App URL (strongly recommended in production)
# -----------------------------------------------------------------------------
# Canonical site URL (https://your-domain.com). Used for email/WhatsApp links.
# Paystack subscription card checkout uses this for callback_url when set; if
# unset, the API falls back to the request Host (live site) or VERCEL_URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Internal — platform announcements admin (optional)
# -----------------------------------------------------------------------------
# Comma-separated emails allowed to open /internal/announcements and manage
# platform_announcements via API. If unset or empty, no one can access internal tools.
INTERNAL_ANNOUNCEMENT_ADMIN_EMAILS=you@yourcompany.com
# Optional: Resend "from" for announcement email batches (default: Finza <documents@mail.finza.africa>)
# INTERNAL_ANNOUNCEMENT_EMAIL_FROM=Finza <documents@mail.finza.africa>
# Max emails per POST (default 75; avoid serverless timeouts)
# INTERNAL_ANNOUNCEMENT_EMAIL_BATCH_MAX=75
# Max business rows scanned when resolving recipients (default 4000)
# INTERNAL_ANNOUNCEMENT_EMAIL_MAX_BUSINESSES_SCAN=4000

# -----------------------------------------------------------------------------
# Signup gate — website-controlled service signup (optional)
# -----------------------------------------------------------------------------
# When NEXT_PUBLIC_SIGNUP_REQUIRE_SERVICE_PLAN_CONTEXT=true, /signup only loads
# for business-owner service signup if the URL includes valid marketing context:
#   workspace=service&plan=<tier>   (tier: starter|essentials|professional|… aliases — see tryParseServiceSubscriptionTier)
# Optional: trial=1, cycle=… (ignored by the gate; reserved for future use).
# Accounting firms bypass the gate with: flow=accounting_firm
# Everyone else is redirected to NEXT_PUBLIC_MARKETING_PRICING_URL (full URL).
# Leave the flag unset or not "true" for local dev and legacy direct /signup access.
# NEXT_PUBLIC_SIGNUP_REQUIRE_SERVICE_PLAN_CONTEXT=true
# NEXT_PUBLIC_MARKETING_PRICING_URL=https://finza.africa/pricing

# -----------------------------------------------------------------------------
# Product demo video — /demo and embedded on /signup (optional override)
# -----------------------------------------------------------------------------
# Default in app: Finza overview on YouTube. Set this to use a different URL
# (youtube.com/watch, youtu.be/…, or youtube.com/embed/…).
# NEXT_PUBLIC_DEMO_VIDEO_URL=https://www.youtube.com/watch?v=ScD8LXyYcTw

# -----------------------------------------------------------------------------
# Retail POS — shared tablet / kiosk (optional)
# -----------------------------------------------------------------------------
# Email/password sessions use cookies and stay signed in after closing the tab.
# Cashiers who only use PIN rely on sessionStorage (clears when the tab closes).
# On shared POS hardware, set a positive number to auto sign out after idle on
# /pos and /retail/pos (mouse, keyboard, scroll, or touch resets the timer).
# Example: NEXT_PUBLIC_RETAIL_POS_IDLE_LOGOUT_MINUTES=15
# NEXT_PUBLIC_RETAIL_POS_IDLE_LOGOUT_MINUTES=
#
# Optional: dedicated secret for PIN cashier POS tokens (receipt API under /retail/pos).
# If unset, a deterministic key is derived from SUPABASE_SERVICE_ROLE_KEY (server-only).
# For production hardening, set a long random value (min 16 characters).
# CASHIER_POS_TOKEN_SECRET=

# -----------------------------------------------------------------------------
# Retail POS — MTN MoMo sandbox checkout (two layers: browser flag + server secrets)
# -----------------------------------------------------------------------------
#
# (A) BROWSER — only turns on the “phone number + Send to phone” UI in checkout.
#     Does NOT talk to MTN. No secrets here.
# NEXT_PUBLIC_RETAIL_MTN_SANDBOX_MOMO=1
#     Truthy: 1 | true | yes | on (case-insensitive)
#
# (B) SERVER — Next.js API routes call MTN. All four below are server-only (no NEXT_PUBLIC_).
#     Get them from https://momodeveloper.mtn.com after you subscribe to “Collections”.
#
#     Think of it as logging into MTN, then telling their gateway which product you use:
#       MTN_MOMO_API_USER              = your sandbox “API user” UUID (like a username)
#       MTN_MOMO_API_KEY               = the one-time “API key” secret paired with that user (password)
#       MTN_MOMO_COLLECTION_SUBSCRIPTION_KEY = long hex from Profile → Collections → Primary key
#                                            (this is NOT the same string as API_KEY)
#       MTN_MOMO_TARGET_ENVIRONMENT    = sandbox   (use mtnghana etc. only for live Ghana keys)
#
#     Order on the portal: subscribe to Collections → copy Primary key → create API user → create API key.
#     Sandbox request-to-pay uses currency EUR in API (Finza maps automatically); your POS total is still GHS in-app.
#
# MTN_MOMO_API_USER=
# MTN_MOMO_API_KEY=
# MTN_MOMO_COLLECTION_SUBSCRIPTION_KEY=
# MTN_MOMO_TARGET_ENVIRONMENT=sandbox
#
# Optional legacy names (only if you do not set MTN_MOMO_* above):
# FINZA_MTN_RETAIL_POS_API_USER=
# FINZA_MTN_RETAIL_POS_API_KEY=
# FINZA_MTN_RETAIL_POS_PRIMARY_KEY=
# FINZA_MTN_RETAIL_POS_TARGET_ENVIRONMENT=sandbox
#
# Optional: force API host (leave unset unless you know you need it).
# With TARGET_ENVIRONMENT=sandbox, Finza defaults to https://sandbox.momodeveloper.mtn.com
# With live targets (e.g. mtnghana), default is https://proxy.momoapi.mtn.com
# MTN_MOMO_COLLECTION_BASE_URL=

# -----------------------------------------------------------------------------
# E2E — Playwright service workspace (optional)
# -----------------------------------------------------------------------------
# Create a Supabase user that lands in the service workspace (industry = service).
# If the user sees /select-workspace, pick the service card or set E2E_SERVICE_BUSINESS_NAME.
# E2E_SERVICE_EMAIL=
# E2E_SERVICE_PASSWORD=
# E2E_SERVICE_BUSINESS_NAME=
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# Receipt OCR (POST /api/receipt-ocr) — free local Tesseract via tesseract.js
# -----------------------------------------------------------------------------
# Omit or set false: run real OCR (first request may download ~eng traineddata~).
# Set true: use stub text only (fast dev, no WASM).
# RECEIPT_OCR_USE_STUB=true
#
# Before OCR, large images are downscaled (sharp) to speed Tesseract / avoid timeouts.
# RECEIPT_OCR_MAX_EDGE_PX=1600
# RECEIPT_OCR_SKIP_DOWNSCALE=true

# -----------------------------------------------------------------------------
# Paystack — card & mobile money (test: sk_test_… / pk_test_… from Dashboard → Settings → API Keys)
# -----------------------------------------------------------------------------
# Server: charge, verify, submit-otp, and webhook HMAC (must match the key pair you use in the dashboard).
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Client: only needed where the UI exposes Paystack (e.g. public pay page). Never put the secret key in NEXT_PUBLIC_*.
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Webhooks (charge.success, etc.): point Paystack to your deployed URL, e.g.
#   https://your-domain.com/api/payments/webhooks/mobile-money
# Local dev: use ngrok/cloudflared and register that URL in Paystack → Settings → Webhooks (test mode).

# -----------------------------------------------------------------------------
# Service workspace subscription — MTN MoMo Collection API (sandbox or live) — optional second gateway
# -----------------------------------------------------------------------------
# Uses the same subscription metadata + applyPaystackSubscriptionWebhook path as Paystack.
# Register your MTN callback URL to POST /api/payments/momo/callback (same host as the app).
# Reuses MTN_MOMO_COLLECTION_BASE_URL if set (defaults to https://proxy.momoapi.mtn.com).
#
# FINZA_MTN_SUBSCRIPTION_API_USER=
# FINZA_MTN_SUBSCRIPTION_API_KEY=
# FINZA_MTN_SUBSCRIPTION_PRIMARY_KEY=
# FINZA_MTN_SUBSCRIPTION_TARGET_ENVIRONMENT=sandbox
#
# Optional default when both Paystack and MTN env vars are set: paystack | mtn_momo_sandbox
# FINZA_SUBSCRIPTION_PAYMENT_GATEWAY=paystack

# -----------------------------------------------------------------------------
# Tenant payment provider config (server-only) — encrypts business_payment_providers.secret_config_encrypted
# -----------------------------------------------------------------------------
# Required for saving integrated provider secrets (MTN/Paystack tenant keys, etc.).
# Must be exactly 32 bytes of key material (after trim), in one of these forms:
#   - 64 hex characters (recommended)
#   - Base64 or base64url encoding of exactly 32 raw bytes
# Do not use passphrases. Do not reuse third-party API keys as this key.
#
# Generate locally:
#   openssl rand -hex 32
#   # or (Windows / no OpenSSL):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Copy the value into .env.local and set the same variable on Vercel (Production
# + Preview) if you deploy. Changing the key later invalidates existing ciphertext.
# TENANT_PAYMENT_CONFIG_ENCRYPTION_KEY=paste_output_of_openssl_or_node_command_here

# -----------------------------------------------------------------------------
# Optional feature flags / integrations
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SERVICE_ANALYTICS_V2=true
# FORENSIC_ALERT_EMAIL=alerts@yourdomain.com
#
# Onboarding AI assistant (optional)
# Uses AI SDK + OpenAI provider in app/api/onboarding/assistant/route.ts
# OPENAI_API_KEY=sk-...
# ONBOARDING_AI_MODEL=gpt-5-mini
#
# Local/open-source assistant via Ollama-compatible OpenAI API
# Defaults in app/api/ai/route.ts:
#   AI_BASE_URL=http://localhost:11434/v1
#   AI_MODEL=gemma3:12b
#   AI_API_KEY=ollama
# AI_BASE_URL=http://localhost:11434/v1
# AI_MODEL=gemma3:12b
# AI_API_KEY=ollama

RECEIPT_OCR_USE_STUB=true

MTN_MOMO_COLLECTION_SUBSCRIPTION_KEY=bdceab40b193470d9d39393bbe3e6571
MTN_MOMO_API_USER=6b1ce14c-1cb8-4d9e-b3d2-70cf9c8f9b35
MTN_MOMO_API_KEY=018db67508e64e87ae9ccffad6863fee
MTN_MOMO_TARGET_ENVIRONMENT=sandbox
NEXT_PUBLIC_RETAIL_MTN_SANDBOX_MOMO=1
