# Finza staging environment — copy to `.env.staging` (gitignored) for local staging runs.
# Never commit real secrets. Never point at production Supabase or app.finza.africa.
#
#   cp .env.staging.example .env.staging
#   # fill values from Supabase staging project + Vercel Preview/Staging
#
# See docs/staging/setup.md

# ── Supabase (staging project only) ─────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=https://adonhhtooawkeemdqqeo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFkb25oaHRvb2F3a2VlbWRxcWVvIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODIxNjE2ODAsImV4cCI6MjA5NzczNzY4MH0.gteoKZMizYHZgxbsiFsNfrb-1CI8Mh8Yps5nuX4xjkc
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFkb25oaHRvb2F3a2VlbWRxcWVvIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4MjE2MTY4MCwiZXhwIjoyMDk3NzM3NjgwfQ.kX4ycRl6QBs77Nro5e_uXVj9es75VgYS59XTFvPWFnY

# For Supabase CLI / direct Postgres (optional)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_STAGING_PROJECT_REF.supabase.co:5432/postgres

# Block accidental use of production (seed scripts + local checks)
FINZA_PRODUCTION_SUPABASE_PROJECT_REF=YOUR_PRODUCTION_PROJECT_REF
FINZA_PRODUCTION_APP_URLS=app.finza.africa,finza.africa

# ── App URL (staging / Vercel preview only) ───────────────────────────────────

# Primary origin used by the app (emails, redirects, public links)
NEXT_PUBLIC_APP_URL=https://YOUR-STAGING-URL.vercel.app

# Alias some tooling expects — keep in sync with NEXT_PUBLIC_APP_URL
NEXT_PUBLIC_SITE_URL=https://YOUR-STAGING-URL.vercel.app

# Vercel sets this automatically on preview deployments
# VERCEL_URL=

# ── Payments — test or disabled in staging ────────────────────────────────────

PAYSTACK_SECRET_KEY=sk_test_
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_

# Tenant invoice online payments (leave false unless testing Paystack test mode)
FINZA_TENANT_INVOICE_ONLINE_PAYMENTS_ENABLED=false

FINZA_SUBSCRIPTION_PAYMENT_GATEWAY=paystack

HUBTEL_ENABLED=false
HUBTEL_MODE=test
HUBTEL_CLIENT_ID=
HUBTEL_CLIENT_SECRET=
HUBTEL_WEBHOOK_SECRET=
HUBTEL_WEBHOOK_PROCESSING_ENABLED=false
HUBTEL_STATUS_CHECK_URL_TEMPLATE=
HUBTEL_STATUS_PROXY_URL=
HUBTEL_STATUS_PROXY_SECRET=

# Encrypt tenant payment provider configs (generate 64 hex chars for staging)
TENANT_PAYMENT_CONFIG_ENCRYPTION_KEY=

# ── Email — test or disabled in staging ───────────────────────────────────────

# Leave empty to no-op outbound email; use Resend test domain if testing
RESEND_API_KEY=
RESEND_FROM=Finza Staging <onboarding@resend.dev>
RESEND_WEBHOOK_SECRET=

# ── Cron / internal (staging-only secrets) ────────────────────────────────────

CRON_SECRET=
REMINDER_API_KEY=

# ── Optional integrations (leave unset in staging unless testing) ───────────

META_WHATSAPP_APP_ID=
META_WHATSAPP_APP_SECRET=

FINZA_INBOUND_EMAIL_DOMAIN=

RECEIPT_OCR_USE_STUB=true

# Forensic alerts — disable in staging
FORENSIC_ALERT_ENABLED=false
FORENSIC_ALERT_EMAIL=
FORENSIC_ALERT_SLACK_WEBHOOK=

# ── Staging load seed (scripts/seed-staging-load-tenant.mjs) ───────────────────

ALLOW_STAGING_LOAD_SEED=false
STAGING_LOAD_TENANT_EMAIL=load-staging-tenant@example.invalid
# Set after onboarding or seed script creates business:
STAGING_LOAD_BUSINESS_ID=

# ── E2E / k6 (optional, never commit real cookies) ────────────────────────────

# PLAYWRIGHT_BASE_URL=https://YOUR-STAGING-URL.vercel.app
# E2E_SERVICE_EMAIL=
# E2E_SERVICE_PASSWORD=

# ── Staging load / dashboard operational gate ─────────────────────────────────

# Default OFF — cluster reads summary/cache only (no refresh in request path).
# FINZA_DASHBOARD_CLUSTER_REFRESH_ON_REQUEST=1

# Default OFF — reports_pnl reads snapshot/cache only (no live/refresh in request path).
# FINZA_REPORTS_PNL_REFRESH_ON_REQUEST=1

# Optional per-instance caches for load tests (see lib/server/dashboardClusterCache.ts)
# FINZA_DASHBOARD_CLUSTER_CACHE_TTL_SEC=30
# FINZA_DASHBOARD_METRICS_CACHE_TTL_SEC=30
# FINZA_PNL_REPORT_CACHE_TTL_SEC=30
# reports_pnl full-response cache defaults to 30s when unset; set 0 to disable
# FINZA_DASHBOARD_PNL_SUMMARY_FAST_PATH=1
